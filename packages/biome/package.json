{
  "bugs": {
    "url": "https://github.com/cleevio/cleeviox-toolkit/issues"
  },
  "description": "Biome configuration used on CleevioX projects",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11"
  },
  "exports": {
    "./base.json": "./base.jsonc",
    "./nestjs.json": "./nestjs.jsonc",
    "./nextjs.json": "./nextjs.jsonc",
    "./react.json": "./react.jsonc"
  },
  "files": [
    "*.jsonc",
    "!package.json"
  ],
  "keywords": [
    "biome",
    "linter",
    "formatter",
    "config",
    "cleevio",
    "cleeviox"
  ],
  "name": "@cleeviox/biome",
  "peerDependencies": {
    "@biomejs/biome": "^2.3.11"
  },
  "repository": {
    "directory": "packages/biome",
    "type": "git",
    "url": "https://github.com/cleevio/cleeviox-toolkit"
  },
  "scripts": {
    "check": "biome check --write .",
    "clean": "del .turbo node_modules",
    "fix": "biome:check:fix",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write ."
  },
  "sideEffects": false,
  "type": "module",
  "version": "0.0.0"
}
