{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "extends": ["./base.jsonc"],
  "linter": {
    "rules": {
      "complexity": {
        "noStaticOnlyClass": "warn",
        "noThisInStatic": "warn"
      },
      "correctness": {
        "noNodejsModules": "off"
      },
      "style": {
        "useGroupedAccessorPairs": "error",
        "useReadonlyClassProperties": "error"
      }
    }
  },
  "root": false
}
