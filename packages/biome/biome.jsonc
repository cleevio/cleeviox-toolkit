{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "extends": ["./base.jsonc"],
  "overrides": [
    {
      "includes": ["**/lint-staged.config.js"],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredDependencies": "off"
          },
          "performance": {
            "noBarrelFile": "off"
          },
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ],
  "root": false
}
