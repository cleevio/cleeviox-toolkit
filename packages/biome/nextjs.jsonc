{
  "$schema": "https://biomejs.dev/schemas/2.4.0/schema.json",
  "extends": ["./reactjs.jsonc"],
  "linter": {
    "rules": {
      "performance": {
        "noImgElement": "error",
        "useGoogleFontPreconnect": "warn"
      },
      "suspicious": {
        "noDocumentImportInPage": "error",
        "noHeadImportInDocument": "error"
      }
    }
  },
  "root": false
}
