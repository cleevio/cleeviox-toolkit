{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSpacing": true,
  "ignorePatterns": ["node_modules", "dist/", "**/*.md"],
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "sortPackageJson": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false
}
